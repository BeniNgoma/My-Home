{
  "name": "caretrack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=apps/web",
    "mobile": "npm run start --workspace=apps/mobile",
    "web": "npm run dev --workspace=apps/web",
    "shared": "npm run build --workspace=packages/shared"
  },
  "devDependencies": {
    "libsodium-wrappers": "^0.8.4",
    "sharp": "^0.34.5",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
